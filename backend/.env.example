DATABASE_URL=postgresql://user:password@localhost:5432/strata
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=
SESSION_SECRET=change-me-in-production
CRON_SECRET=
# For CORS when frontend is on another domain (e.g. Vercel). No trailing slash.
FRONTEND_URL=
# Stripe: $29/mo subscription, first month free.
# Secret key: Dashboard → Developers → API keys (sk_live_... or sk_test_...)
# Price ID: Dashboard → your Product → open the Price ($29/mo) → copy "API ID" (price_...) — not the Product ID (prod_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
PORT=3001
LOG_LEVEL=info

# Google OAuth (sign in / sign up with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
