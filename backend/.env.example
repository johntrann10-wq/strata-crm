# Required for production (and for local dev unless you rely on dev defaults in code)
DATABASE_URL=postgresql://user:password@localhost:5432/strata
JWT_SECRET=change-me-to-a-random-string-in-production
FRONTEND_URL=http://localhost:5173
# Optional — comma-separated extra exact origins for CORS (e.g. call Railway from local Vite: http://localhost:5173)
# FRONTEND_ALLOWED_ORIGINS=http://localhost:5173
# Optional — local dev frontend origin if not using 5173 (non-production only)
# FRONTEND_DEV_URL=http://localhost:3000
PORT=3001

# Optional: session cookie signing (defaults to JWT_SECRET if unset)
SESSION_SECRET=change-me-in-production

# Optional: defaults to "info"
LOG_LEVEL=info

# Optional — email (omit to run without SMTP; startup logs "SMTP disabled")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_SECURE=true

# Optional — Stripe billing (omit to run without Stripe; startup logs "Stripe disabled")
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Optional — if set, POST /api/actions/runAutomations requires header x-cron-secret
# CRON_SECRET=change-me-to-a-random-string-in-production

# Backend API base used for Google OAuth redirect URIs (no trailing slash). Required if Google OAuth is enabled.
API_BASE=http://localhost:3001

# Google OAuth (optional — only required when using Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
