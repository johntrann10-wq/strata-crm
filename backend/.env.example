# Required for production (and for local dev unless you rely on dev defaults in code)
DATABASE_URL=postgresql://user:password@localhost:5432/strata
JWT_SECRET=replace-with-a-long-random-jwt-secret
# Must be the SPA origin only: scheme + host + optional port, with no path, query, hash, or trailing slash.
FRONTEND_URL=http://localhost:5173
# Optional - comma-separated extra exact origins for CORS (e.g. call Railway from local Vite: http://localhost:5173)
# FRONTEND_ALLOWED_ORIGINS=http://localhost:5173
# Optional - local dev frontend origin if not using 5173 (non-production only)
# FRONTEND_DEV_URL=http://localhost:3000
PORT=3001

# Optional: defaults to "info"
LOG_LEVEL=info

# Optional - transactional email. Resend is recommended in production.
# RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM=Strata CRM <notifications@stratacrm.app>

# Optional - SMTP fallback (omit to run without SMTP; startup logs show it only when configured)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=strata.interface@gmail.com
# SMTP_PASS=your-16-char-gmail-app-password
# SMTP_FROM=Strata CRM <strata.interface@gmail.com>
# SMTP_SECURE=true

# Optional - Stripe billing (omit to run without Stripe; startup logs "Stripe disabled")
# STRIPE_SECRET_KEY=replace-with-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
# STRIPE_PRICE_ID=replace-with-stripe-price-id

# Optional - if set, POST /api/actions/runAutomations requires header x-cron-secret
# CRON_SECRET=replace-with-a-long-random-cron-secret

# Optional - reverse proxy handling in production, e.g. loopback or true
# TRUST_PROXY=loopback

# Optional - lightweight client/runtime diagnostics forwarded to backend logs
# CLIENT_ERROR_REPORTING_ENABLED=true

# Backend API base used for provider callback URLs (no trailing slash). Required for Google Calendar,
# QuickBooks, and Twilio delivery/status callbacks.
API_BASE=http://localhost:3001

# Google OAuth (optional - required when using Google Calendar integration)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# QuickBooks Online OAuth (optional - required when using QuickBooks integration)
QUICKBOOKS_CLIENT_ID=replace-with-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=replace-with-quickbooks-client-secret

# Integration feature flags. Provider flows remain disabled until the relevant flag is true.
FEATURE_INTEGRATION_QUICKBOOKS_ONLINE=false
FEATURE_INTEGRATION_GOOGLE_CALENDAR=false
FEATURE_INTEGRATION_TWILIO_SMS=false
FEATURE_INTEGRATION_OUTBOUND_WEBHOOKS=false

# Recommended if enabling QuickBooks, Google Calendar, Twilio, or encrypted outbound webhook secrets
# INTEGRATION_VAULT_SECRET=replace-with-a-long-random-vault-secret
# INTEGRATION_VAULT_KEY_ID=current
# INTEGRATION_VAULT_PREVIOUS_SECRET=replace-with-the-previous-vault-secret-during-rotation
# INTEGRATION_VAULT_PREVIOUS_KEY_ID=previous
