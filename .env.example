# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/strata

# JWT_SECRET — required for:
# - POST /api/auth/sign-in
# - POST /api/auth/sign-up
# - GET /api/auth/me
JWT_SECRET=change-me-to-a-random-string-in-production

# SMTP (Gmail) — use an App Password, not your regular Gmail password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_SECURE=true

# Backend (optional for frontend)
SESSION_SECRET=change-me-to-a-random-string-in-production

# Used by the backend for redirects and CORS.
FRONTEND_URL=http://localhost:5173

API_BASE=http://localhost:3001

# Automations (cron)
CRON_SECRET=change-me-to-a-random-string-in-production

# Server runtime
PORT=3001
LOG_LEVEL=info

# Frontend API base URL (Vite env var)
VITE_API_URL=http://localhost:3001

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_PRICE_ID=price_change_me

# Google OAuth (optional, but env contract expects these)
GOOGLE_CLIENT_ID=google-client-id-change_me
GOOGLE_CLIENT_SECRET=google-client-secret-change_me
