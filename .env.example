# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/strata

# JWT secret used by backend-issued access tokens.
JWT_SECRET=replace-with-a-long-random-jwt-secret

# SMTP (optional) — use an App Password, not your regular Gmail password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=replace-with-your-smtp-app-password
SMTP_FROM=your-email@gmail.com
SMTP_SECURE=true

# Used by the backend for redirects, Google OAuth, Stripe, and CORS.
# Must be the SPA origin only: scheme + host + optional port, with no path, query, hash, or trailing slash.
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated extra allowed browser origins for CORS (e.g. Vercel preview URLs, or local dev when the SPA calls a deployed API).
# FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,https://your-app-git-branch.vercel.app

API_BASE=http://localhost:3001

# Automations (cron)
CRON_SECRET=replace-with-a-long-random-cron-secret

# Server runtime
PORT=3001
LOG_LEVEL=info

# Frontend: API origin for browser requests (Vite; baked in at build time). Use ONE of:
# - VITE_API_URL — preferred
# - NEXT_PUBLIC_API_URL — same meaning (for hosts that only expose NEXT_PUBLIC_*)
# No trailing slash. For local dev, points at the Express API (Vite proxies /api to this origin).
VITE_API_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=

# Production build guard (see vite.config.mts): required unless you set an API origin above.
# Set to true when the SPA uses same-origin /api and the host edge proxies to the backend (Netlify/Vercel).
# Committed defaults: see .env.production
# VITE_ALLOW_RELATIVE_API=true

# Vercel / Netlify only — server env for the same-origin /api edge proxy (not baked into the SPA).
# STRATA_API_ORIGIN=https://your-api.example.com

# Reverse proxy handling (production hosts only). Examples: loopback, 1, true.
# TRUST_PROXY=loopback

# Billing (Stripe)
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_ID=replace-with-stripe-price-id

# Google OAuth (optional, but env contract expects these)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Resend (optional email provider)
# RESEND_API_KEY=replace-with-resend-api-key
# RESEND_FROM=Strata CRM <notifications@example.com>
# EMAIL_REPLY_TO=support@example.com

# iOS universal links / associated domains (production builds only)
# Format: <Apple Team ID>.<Bundle Identifier>
# Example: ABCDE12345.com.stratacrm.mobile
# IOS_APP_IDENTIFIER=replace-with-your-ios-app-identifier
# For multiple iOS apps, use a comma-separated list instead:
# IOS_APP_IDENTIFIERS=ABCDE12345.com.stratacrm.mobile,ABCDE12345.com.stratacrm.mobile.beta

# Integration encryption (recommended when enabling provider integrations or outbound webhook secrets)
# INTEGRATION_VAULT_SECRET=replace-with-a-long-random-vault-secret
# INTEGRATION_VAULT_KEY_ID=current
# INTEGRATION_VAULT_PREVIOUS_SECRET=replace-with-the-previous-vault-secret-during-rotation
# INTEGRATION_VAULT_PREVIOUS_KEY_ID=previous
