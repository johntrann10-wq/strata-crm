# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/strata

# SMTP (Gmail) — use an App Password, not your regular Gmail password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Backend (optional for frontend)
SESSION_SECRET=change-me-to-a-random-string-in-production
PORT=3001
