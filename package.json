{
  "name": "strata",
  "version": "0.1.0",
  "description": "Strata CRM — SPA (web/) + Node API (backend/)",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "build": "react-router build && node scripts/verify-client-bundle.mjs",
    "dev": "react-router dev",
    "build:backend": "npm --prefix backend run build",
    "dev:backend": "npm --prefix backend run dev",
    "lint": "eslint .",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate": "npm --prefix backend run db:migrate",
    "test": "npm run test:backend",
    "test:backend": "npm --prefix backend run test",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test e2e/mobile-core.spec.ts --project=mobile-chrome",
    "test:e2e:reliability": "playwright test e2e/reliability-diagnostics.spec.ts e2e/soak-navigation.mocked.spec.ts",
    "predeploy": "npm run scan:secrets && npm run lint && npm run test:backend && npm run build:backend && npm run build",
    "run:db": "docker compose up -d",
    "run": "node run-local.cjs"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "*",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-navigation-menu": "*",
    "@radix-ui/react-popover": "^1.1.5",
    "@radix-ui/react-progress": "*",
    "@radix-ui/react-radio-group": "*",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "*",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "*",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@tailwindcss/vite": "^4.1.7",
    "@vercel/react-router": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^4.1.0",
    "isbot": "^5.1.0",
    "lucide-react": "^0.471.1",
    "react": "^19.1.2",
    "react-day-picker": "^9.5.1",
    "react-dom": "^19.1.2",
    "react-router": "^7.12.0",
    "sonner": "^1.7.2",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.12.0",
    "@remix-run/dev": "^2.11.1",
    "@types/node": "^22.13.14",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.2.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
