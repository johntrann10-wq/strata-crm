{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path].ts"
    },
    {
      "source": "/((?!api/|assets/|marketing/|qa/|book/|lead/|favicon\\.svg$|apple-touch-icon\\.png$|robots\\.txt$|sitemap\\.xml$|googleb90dd9f849dc96e5\\.html$|social-preview\\.png$).*)",
      "destination": "/index.html"
    }
  ]
}
