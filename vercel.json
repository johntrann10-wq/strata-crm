{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/book/:businessId",
      "destination": "/api/public-share-shell?surface=booking&businessId=:businessId"
    },
    {
      "source": "/lead/:businessId",
      "destination": "/api/public-share-shell?surface=lead&businessId=:businessId"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/[...path].ts"
    },
    {
      "source": "/((?!api/|assets/|marketing/|qa/|favicon\\.svg$|apple-touch-icon\\.png$|robots\\.txt$|sitemap\\.xml$|googleb90dd9f849dc96e5\\.html$|social-preview\\.png$|apple-app-site-association$|\\.well-known/apple-app-site-association$).*)",
      "destination": "/index.html"
    }
  ]
}
